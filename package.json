{
  "name": "alkamanas-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alkamanas/ui.git"
  },
  "bugs": {
    "url": "https://github.com/alkamanas/ui/issues"
  },
  "homepage": "https://github.com/alkamanas/ui#readme",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @alkamanas/ui build && pnpm --filter @alkamanas/cli build && pnpm --filter @alkamanas/docs build",
    "dev": "pnpm --filter @alkamanas/ui build && pnpm --filter @alkamanas/docs dev",
    "lint": "eslint apps/docs/src apps/docs/vite.config.ts packages/ui/src packages/cli/src",
    "test": "vitest run --config packages/ui/vitest.config.ts",
    "typecheck": "pnpm --filter @alkamanas/ui typecheck && pnpm --filter @alkamanas/cli typecheck && pnpm --filter @alkamanas/docs typecheck",
    "pack:ui": "pnpm --dir packages/ui pack --pack-destination /tmp",
    "pack:cli": "pnpm --dir packages/cli pack --pack-destination /tmp",
    "registry:update": "node scripts/update-registry.mjs",
    "registry:check": "node scripts/update-registry.mjs --check",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm registry:check && pnpm build && pnpm pack:ui && pnpm pack:cli"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.2",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest-axe": "3.5.9",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "turbo": "^2.6.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
